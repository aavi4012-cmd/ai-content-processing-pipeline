# AI Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_pipeline

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Provider ─────────────────────────────────────────────
# Leave blank to use mock LLM responses (great for testing without API costs)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# ── Retry Configuration ─────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF=True
